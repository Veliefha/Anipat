@model Anipat.ViewModels.HomeVM

<div class="slider_area">
    <div class="single_slider slider_bg_1 d-flex align-items-center">
        <div class="container">
            <div class="row">
                <div class="col-lg-5 col-md-6">
                    <div class="slider_text">
                        <h3>Ev Heyvanlarınıza <br> <span>Peşəkar Xidmət</span></h3>
                        <a asp-controller="Contact" asp-action="Index" class="boxed-btn4">Əlaqə</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="dog_thumb d-none d-lg-block">
            <img src="~/img/banner/dog.png" alt="">
        </div>
    </div>
</div>

<div class="service_area">
    <div class="container">
        <div class="row justify-content-center ">
            <div class="col-lg-7 col-md-10">
                <div class="section_title text-center mb-95">
                    <h3>Hər bir heyvan üçün xidmətlər</h3>
                    <p>Ev heyvanlarınızın sağlamlığı, qidalanması və gündəlik baxımı üçün peşəkar xidmətlər təqdim edirik.</p>
                </div>
            </div>
        </div>
        <div class="row justify-content-center">
            @foreach (var service in Model.Services)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="single_service @(service.IsActive ? "active" : "")">
                        <div class="service_thumb service_icon_bg_1 d-flex align-items-center justify-content-center">
                            <div class="service_icon">
                                <img src="~/img/service/@service.IconPath" alt="@service.Title">
                            </div>
                        </div>
                        <div class="service_content text-center">
                            <h3>@service.Title</h3>
                            <p>@service.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="adapt_area" id="pet-section">
    <div class="container">
        <div class="row justify-content-center align-items-center mb-5">
            <div class="col-lg-7 text-center">
                <div class="adapt_help">
                    <div class="section_title">
                        <h3><span>Sizin dəstəyinizə</span> Ehtiyacımız Var – Sahiblənin</h3>
                        <p>Sahibsiz heyvanlara yeni və sevgi dolu bir ailə tapmaq üçün bizimlə əməkdaşlıq edin.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row justify-content-center mt-5">
            @foreach (var pet in Model.LatestPets)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="single_adapt text-center mb-5">
                        <div class="pet_image_wrapper position-relative">
                            <img src="~/img/pets/@pet.ImageUrl" style="width: 200px; height: 200px; border-radius: 50%; object-fit: cover; border: 5px solid #fff; box-shadow: 0 5px 15px rgba(0,0,0,0.1);" alt="@pet.Name">
                        </div>
                        <div class="adapt_content">
                            <h3 class="mt-3">@pet.Name</h3>
                            <p class="mb-3">@pet.Breed (@pet.Age yaş)</p>
                            <a href="/Pet/Details/@pet.Id" class="boxed-btn3">Məni Sahiblən</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            <div class="col-12 text-center mt-3">
                <a asp-controller="Pet" asp-action="Index" class="boxed-btn3"
                   style="background: #ff3500; border: 1px solid #ff3500; padding: 12px 35px; white-space: nowrap; display: inline-block; color: white;">
                    Bütün Dostlarımızı Gör
                </a>
            </div>
        </div>
    </div>
</div>

@* Statistika və digər scriptlər saxlanılır, geolokasiya silinir *@
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Statistika sayğacı (Counter)
        const counters = document.querySelectorAll('.counter');
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const el = entry.target;
                    const target = +el.getAttribute('data-target');
                    const updateCount = () => {
                        const current = +el.innerText;
                        const increment = target / 100;
                        if (current < target) {
                            el.innerText = Math.ceil(current + increment);
                            setTimeout(updateCount, 20);
                        } else { el.innerText = target; }
                    };
                    updateCount();
                    observer.unobserve(el);
                }
            });
        }, { threshold: 0.5 });
        counters.forEach(count => observer.observe(count));
    });
</script>