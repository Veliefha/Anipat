@model Pet
@using Anipat.Models
@{
    Layout = "_AdminLayout";
}

<h2 class="mb-4">✨ @Model.Name məlumatlarını yenilə</h2>

<div class="card p-4 shadow-sm" style="border-radius: 20px;">
    <form asp-action="Update" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImageUrl" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="font-weight-bold">Ad</label>
                <input asp-for="Name" class="form-control" style="border-radius: 10px;" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="font-weight-bold">Cins</label>
                <input asp-for="Breed" class="form-control" style="border-radius: 10px;" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Yaş</label>
                <input asp-for="Age" type="number" class="form-control" style="border-radius: 10px;" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Şəhər</label>
                <input asp-for="City" class="form-control" style="border-radius: 10px;" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Enerji Səviyyəsi</label>
                <select asp-for="Energy" class="form-control" style="border-radius: 10px;" asp-items="Html.GetEnumSelectList<EnergyLevel>()"></select>
            </div>
        </div>

        <div class="mb-3">
            <label class="font-weight-bold">Təsvir</label>
            <textarea asp-for="Description" class="form-control" rows="3" style="border-radius: 10px;"></textarea>
        </div>

        <div class="form-group mb-4">
            <label class="font-weight-bold text-primary"><i class="fas fa-map-marker-alt"></i> Məkanı Redaktə Et</label>
            <div id="map" style="height: 350px; border-radius: 15px; border: 2px solid #e9ecef;"></div>
            <small class="text-muted">Məkanı dəyişmək üçün xəritədə yeni yerə klikləyin.</small>

            <input type="hidden" asp-for="Latitude" id="LatInput" />
            <input type="hidden" asp-for="Longitude" id="LngInput" />
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <div class="form-check">
                    <input asp-for="IsKidsFriendly" class="form-check-input" type="checkbox" id="kidsCheck">
                    <label class="form-check-label" for="kidsCheck">Uşaqlarla dostdur</label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-check">
                    <input asp-for="IsAdopted" class="form-check-input" type="checkbox" id="adoptCheck">
                    <label class="form-check-label text-success font-weight-bold" for="adoptCheck">Övladlığa götürülüb</label>
                </div>
            </div>
        </div>

        <div class="mb-3 border p-3 rounded bg-light">
            <label class="font-weight-bold">Hazırkı Şəkil</label> <br />
            <img src="~/img/pets/@Model.ImageUrl" width="150" height="150" style="object-fit: cover;" class="img-thumbnail mb-2 shadow-sm" />
            <div class="mt-2">
                <label class="small text-danger font-weight-bold">Şəkli dəyişmək istəyirsinizsə, yenisini seçin:</label>
                <input asp-for="ImageFile" type="file" class="form-control" style="border-radius: 10px;" />
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary btn-lg shadow">Dəyişiklikləri Yadda Saxla</button>
            <a asp-action="Index" class="btn btn-light btn-lg border">Geri</a>
        </div>
    </form>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        // Bazadakı koordinatları götürürük
        var oldLat = @(Model.Latitude != 0 ? Model.Latitude : 40.4093);
        var oldLng = @(Model.Longitude != 0 ? Model.Longitude : 49.8671);

        // Xəritəni köhnə koordinatlara fokuslayırıq
        var map = L.map('map').setView([oldLat, oldLng], 14);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap'
        }).addTo(map);

        // Köhnə koordinatda markeri göstəririk
        var marker = L.marker([oldLat, oldLng]).addTo(map);

        // Xəritəyə yeni klik edildikdə yeri dəyişirik
        map.on('click', function (e) {
            var lat = e.latlng.lat;
            var lng = e.latlng.lng;

            if (marker) {
                map.removeLayer(marker);
            }

            marker = L.marker([lat, lng]).addTo(map);

            document.getElementById('LatInput').value = lat;
            document.getElementById('LngInput').value = lng;
        });
    </script>
}