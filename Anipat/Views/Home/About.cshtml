@{
    ViewData["Title"] = "Haqqımızda";
    Layout = "_Layout";
}

<div class="bradcam_area breadcam_bg">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="bradcam_text text-center">
                    <h3>Haqqımızda</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="pet_care_area">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5 col-md-6">
                <div class="pet_thumb">
                    <img src="~/img/about/pet_care.png" alt="Anipat Qayğı">
                </div>
            </div>
            <div class="col-lg-6 offset-lg-1 col-md-6">
                <div class="pet_info">
                    <div class="section_title">
                        <h3><span>Biz sizin heyvanınıza</span> <br> Sizin qədər qayğı göstəririk</h3>
                        <p>Anipat olaraq sevimli dostlarınızın sağlamlığı və xoşbəxtliyi bizim üçün prioritetdir. Biz onlara peşəkar baytarlıq xidməti və sonsuz sevgi ilə yanaşırıq.</p>
                        <a href="/Home/Contact" class="boxed-btn3">Bizimlə Əlaqə</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="adapt_area">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-12">
                <div class="adapt_about">
                    <div class="row align-items-center">
                        <div class="col-lg-4 col-md-4">
                            <div class="single_adapt text-center">
                                <img src="~/img/adapt_icon/1.png" alt="">
                                <div class="adapt_content">
                                    <h3><span class="counter" data-target="452">0</span></h3>
                                    <p>Mövcud Heyvanlar</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-4">
                            <div class="single_adapt text-center">
                                <img src="~/img/adapt_icon/3.png" alt="">
                                <div class="adapt_content">
                                    <h3><span class="counter" data-target="52">0</span>+</h3>
                                    <p>Xilas Edilənlər</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-md-4">
                            <div class="single_adapt text-center">
                                <img src="~/img/adapt_icon/2.png" alt="">
                                <div class="adapt_content">
                                    <h3><span class="counter" data-target="120">0</span>+</h3>
                                    <p>Xoşbəxt Yuvalar</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const counters = document.querySelectorAll('.counter');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const el = entry.target;
                        const target = +el.getAttribute('data-target');
                        const updateCount = () => {
                            const current = +el.innerText;
                            const increment = target / 50;
                            if (current < target) {
                                el.innerText = Math.ceil(current + increment);
                                setTimeout(updateCount, 30);
                            } else { el.innerText = target; }
                        };
                        updateCount();
                        observer.unobserve(el);
                    }
                });
            }, { threshold: 0.5 });
            counters.forEach(count => observer.observe(count));
        });
    </script>
}