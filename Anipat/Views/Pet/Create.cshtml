@model Pet
@using Anipat.Models
@{
    Layout = "_AdminLayout";
}

<h2 class="header-title mb-4">🐾 Yeni Heyvan Dostu Əlavə Et</h2>

<div class="card card-cici shadow-sm border-0 p-4" style="border-radius: 20px;">
    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Adı</label>
                <input asp-for="Name" class="form-control" style="border-radius: 12px;" placeholder="Məs: Dostik" required />
            </div>
            @* YENİ: Heyvanın Növü Seçimi *@
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Heyvanın Növü</label>
                <select asp-for="Species" class="form-control" style="border-radius: 12px;"
                        asp-items="Html.GetEnumSelectList<PetSpecies>()">
                    <option value="">Növü seçin...</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Cinsi (Breed)</label>
                <input asp-for="Breed" class="form-control" style="border-radius: 12px;" placeholder="Məs: Golden Retriever" required />
            </div>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Yaşı</label>
                <input asp-for="Age" type="number" class="form-control" style="border-radius: 12px;" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Şəhər</label>
                <input asp-for="City" class="form-control" style="border-radius: 12px;" placeholder="Məs: Bakı" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="font-weight-bold">Enerji Səviyyəsi</label>
                <select asp-for="Energy" class="form-control" style="border-radius: 12px;"
                        asp-items="Html.GetEnumSelectList<EnergyLevel>()">
                    <option value="">Enerji seçin...</option>
                </select>
            </div>
        </div>

        <div class="mb-4">
            <label class="font-weight-bold">Haqqında Qısa Məlumat</label>
            <textarea asp-for="Description" class="form-control" rows="3" style="border-radius: 12px;" placeholder="Xarakteri, vərdişləri..."></textarea>
            <small class="text-muted">Boş qoysanız, sistem avtomatik təsvir yaradacaq.</small>
        </div>

        <div class="form-group mb-4">
            <label class="font-weight-bold text-primary"><i class="fas fa-map-marker-alt"></i> Xəritədən Məkanı Seçin</label>
            <div id="map" style="height: 350px; border-radius: 15px; border: 2px solid #e9ecef;"></div>
            <input type="hidden" asp-for="Latitude" id="LatInput" />
            <input type="hidden" asp-for="Longitude" id="LngInput" />
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <div class="custom-control custom-checkbox">
                    <input asp-for="IsKidsFriendly" class="custom-control-input" id="kidsCheck">
                    <label class="custom-control-label" for="kidsCheck">Uşaqlarla dostdur?</label>
                </div>
            </div>
            <div class="col-md-6">
                <div class="custom-control custom-checkbox">
                    <input asp-for="IsAdopted" class="custom-control-input" id="adoptCheck">
                    <label class="custom-control-label text-success font-weight-bold" for="adoptCheck">Artıq sahiblənilib?</label>
                </div>
            </div>
        </div>

        <div class="form-group mb-4">
            <label class="font-weight-bold text-danger">Şəkil Seçin</label>
            <input asp-for="ImageFile" type="file" class="form-control-file p-2 border w-100" style="border-radius: 12px;" accept="image/*" required />
        </div>

        <hr />

        <div class="d-flex justify-content-start mt-4">
            <button type="submit" class="btn btn-success mr-2 shadow-sm px-4 py-2" style="border-radius: 12px;">
                <i class="fas fa-save mr-1"></i> Sistemi Yadda Saxla
            </button>
            <a asp-action="Index" class="btn btn-light text-muted border px-4 py-2" style="border-radius: 12px;">
                <i class="fas fa-arrow-left mr-1"></i> Geri Qayıt
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        var map = L.map('map').setView([40.4093, 49.8671], 11);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
        var marker;

        map.on('click', function (e) {
            var lat = e.latlng.lat;
            var lng = e.latlng.lng;
            if (marker) map.removeLayer(marker);
            marker = L.marker([lat, lng]).addTo(map);
            document.getElementById('LatInput').value = lat;
            document.getElementById('LngInput').value = lng;
        });

        map.locate({ setView: true, maxZoom: 15 });
        map.on('locationfound', function(e) {
            if (marker) map.removeLayer(marker);
            marker = L.marker(e.latlng).addTo(map);
            document.getElementById('LatInput').value = e.latlng.lat;
            document.getElementById('LngInput').value = e.latlng.lng;
        });
    </script>
}